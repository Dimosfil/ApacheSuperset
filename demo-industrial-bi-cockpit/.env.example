# Demo-only local defaults. Do not reuse these values in production.
COMPOSE_PROJECT_NAME=industrial-bi-cockpit

SUPERSET_IMAGE=apache/superset:latest
SUPERSET_BIND_HOST=0.0.0.0
SUPERSET_PUBLIC_HOST=localhost
SUPERSET_PUBLIC_PROTOCOL=http
SUPERSET_PORT=8088
SUPERSET_PUBLIC_PORT=8088
SUPERSET_SECRET_KEY=change-me-industrial-bi-cockpit-demo-key
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_FIRSTNAME=Demo
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_DEFAULT_LOCALE=en
SUPERSET_PROJECT_LOCALE=en

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=industrial_bi
POSTGRES_USER=industrial
POSTGRES_PASSWORD=industrial

REDIS_HOST=redis
REDIS_PORT=6379

# Optional text-to-chart PoC. Keep real keys only in local .env or environment.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_CHART_ASSISTANT_PORT=8099
